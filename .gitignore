# Root .gitignore for the monorepo

# Node deps
/node_modules

# Monorepo tools
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build output
/dist
/build
/.next
/out

# Service worker files (generated)
**/public/sw.js
**/public/workbox-*.js

# Env files (do NOT commit real secrets)
.env
.env.*

# Track example env files (allow committing these)
!.env.example
!**/.env.example
!**/.env.*.example

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
.pnpm-debug.log*

# OS
.DS_Store

# Editor directories
.vscode
.idea

# Tests
/coverage
/.nyc_output

# Misc
*.pem

# Temporary
.temp
.tmp

# TypeScript build info
*.tsbuildinfo
**/*.tsbuildinfo

# Lock files (optional to ignore depending on workflow)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

.mcp.json