{
	"name": "@widgetable/client",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "npm-run-all --parallel dev:next dev:ts",
		"start:dev": "npm run dev",
		"dev:next": "next dev -H 0.0.0.0 -p 3000 --webpack",
		"dev:ts": "tsc --noEmit --watch --preserveWatchOutput",
		"build": "next build --webpack && cp -r public .next/standalone/apps/client/public && cp -r .next/static .next/standalone/apps/client/.next/static",
		"start": "HOSTNAME=0.0.0.0 PORT=${PORT:-3000} node .next/standalone/apps/client/server.js",
		"lint": "eslint \"src/**/*.{ts,tsx}\" --fix",
		"format": "prettier --config ../../prettier.config.js --write \"src/**/*.{ts,tsx}\"",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@nsmr/pixelart-react": "^2.0.0",
		"@reduxjs/toolkit": "^2.11.2",
		"@widgetable/i18n": "file:../../packages/i18n",
		"@widgetable/types": "file:../../packages/types",
		"axios": "^1.13.2",
		"next": "^16.1.0",
		"next-pwa": "^5.6.0",
		"prettier": "^3.7.4",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"react-hot-toast": "^2.6.0",
		"react-redux": "^9.2.0",
		"redux-persist": "^6.0.0",
		"uninstall": "^0.0.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@tailwindcss/postcss": "^4.1.18",
		"@types/multer": "^2.0.0",
		"@types/next-pwa": "^5.6.9",
		"@types/node": "^25.0.3",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"globals": "^16.5.0",
		"typescript-eslint": "^8.54.0",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"npm-run-all": "^4.1.5",
		"tailwindcss": "^4",
		"typescript": "^5.9.3",
		"webpack": "^5.104.1"
	}
}
