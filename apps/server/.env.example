# Environment variables for apps/server
# Copy to .env and fill values; do NOT commit real secrets.

# URL of the client app (for CORS / emails / redirects)
CLIENT_URL=

# MongoDB connection string
MONGODB_URI=

# JWT signing secret
JWT_SECRET=

# MinIO / S3-compatible storage
STORAGE_ENDPOINT=
STORAGE_PORT=
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Web Push (VAPID) keys — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@email.com

# Optional: override server port
# PORT=
